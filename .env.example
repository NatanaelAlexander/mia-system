# Copia este archivo a .env y ajusta los valores en tu máquina:
#   cp .env.example .env
#
# .env NO se sube a Git (está en .gitignore).

# PostgreSQL — servicio bd_main en docker-compose
POSTGRES_USER=mia_user
POSTGRES_PASSWORD=changeme_dev_only
POSTGRES_DB=mia_system
POSTGRES_PORT=5432

# Backend NestJS (hostname bd_main = red interna de Docker)
DATABASE_URL=postgresql://mia_user:changeme_dev_only@bd_main:5432/mia_system

# Zona horaria IANA (todos los contenedores + Postgres TIMESTAMPTZ / NOW())
TZ=America/Santiago
PGTZ=America/Santiago

# Cloudflare R2 (assets / archivos) — BUCKET PRIVADO
R2_ENDPOINT_URL=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_SYSTEM=mia-system

# JWT — generar secretos fuertes en producción (openssl rand -base64 48)
JWT_ACCESS_SECRET=change_me_access_secret_dev_only
JWT_REFRESH_SECRET=change_me_refresh_secret_dev_only
JWT_ACCESS_EXPIRES_IN_PORTAL=12h
JWT_ACCESS_EXPIRES_IN_INTERNAL=1d
JWT_REFRESH_EXPIRES_IN=7d

# Redis — pub/sub para Socket.IO (tiempo real entre réplicas de api)
REDIS_URL=redis://redis:6379
REDIS_PORT=6379

# Frontend Next.js (desde el navegador del host)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Seguridad HTTP (opcional; en Docker ver docker-compose.yml → api → CORS_ORIGINS)
# CORS_ORIGINS=http://localhost:3001,https://tu-dominio.cl
# TRUST_PROXY=true
# SWAGGER_ENABLED=true
# THROTTLE_TTL_MS=60000
# THROTTLE_LIMIT=120
